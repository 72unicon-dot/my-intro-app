# =====================================================================
# Supabase 키 (Supabase Dashboard → Project Settings → API)
# 이 파일은 키 "이름"만 공유하는 예시입니다. 실제 값은 .env.local 에 적습니다.
# =====================================================================

# 클라이언트에서도 사용 가능한 공개 키 (anon)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# =====================================================================
# 관리자 페이지(/admin) 전용 — 서버에서만 사용됩니다
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요. (브라우저에 노출됨)
# =====================================================================

# /admin 페이지 입장 비밀번호 — 본인이 임의로 정합니다
ADMIN_PASSWORD=change-me-please

# Supabase service role key (Dashboard → Settings → API → service_role)
# 이 키는 RLS를 우회하므로 절대 외부에 공유 금지
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
